<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <PackageType>Template</PackageType>
    <PackageVersion>2.29.15-beta</PackageVersion>
    <PackageId>TestTrackingDiagrams.Templates</PackageId>
    <Title>TestTrackingDiagrams Project Templates</Title>
    <Authors>Aryeh Citron</Authors>
    <Description>dotnet new templates for creating test projects pre-configured with TestTrackingDiagrams dependency tracking and report generation. Supports xUnit v3, xUnit v2, TUnit, NUnit 4, MSTest, LightBDD, BDDfy, and ReqNRoll.</Description>
    <PackageTags>dotnet-new;templates;testing;diagrams;bdd;plantuml;sequence-diagram;xunit;nunit;mstest;tunit;lightbdd;reqnroll;bddfy</PackageTags>
    <PackageLicenseFile>LICENSE</PackageLicenseFile>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <PackageProjectUrl>https://github.com/lemonlion/TestTrackingDiagrams</PackageProjectUrl>
    <RepositoryUrl>https://github.com/lemonlion/TestTrackingDiagrams</RepositoryUrl>

    <TargetFramework>netstandard2.0</TargetFramework>
    <IncludeContentInPack>true</IncludeContentInPack>
    <IncludeBuildOutput>false</IncludeBuildOutput>
    <SuppressDependenciesWhenPacking>true</SuppressDependenciesWhenPacking>
    <ContentTargetFolders>content</ContentTargetFolders>
    <NoDefaultExcludes>true</NoDefaultExcludes>
    <NoWarn>$(NoWarn);NU5128</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <Content Include="ttd-xunit3\**\*" Exclude="ttd-xunit3\**\bin\**;ttd-xunit3\**\obj\**" />
    <Content Include="ttd-xunit2\**\*" Exclude="ttd-xunit2\**\bin\**;ttd-xunit2\**\obj\**" />
    <Content Include="ttd-tunit\**\*" Exclude="ttd-tunit\**\bin\**;ttd-tunit\**\obj\**" />
    <Content Include="ttd-nunit4\**\*" Exclude="ttd-nunit4\**\bin\**;ttd-nunit4\**\obj\**" />
    <Content Include="ttd-mstest\**\*" Exclude="ttd-mstest\**\bin\**;ttd-mstest\**\obj\**" />
    <Content Include="ttd-lightbdd-xunit3\**\*" Exclude="ttd-lightbdd-xunit3\**\bin\**;ttd-lightbdd-xunit3\**\obj\**" />
    <Content Include="ttd-lightbdd-xunit2\**\*" Exclude="ttd-lightbdd-xunit2\**\bin\**;ttd-lightbdd-xunit2\**\obj\**" />
    <Content Include="ttd-lightbdd-tunit\**\*" Exclude="ttd-lightbdd-tunit\**\bin\**;ttd-lightbdd-tunit\**\obj\**" />
    <Content Include="ttd-bddfy-xunit3\**\*" Exclude="ttd-bddfy-xunit3\**\bin\**;ttd-bddfy-xunit3\**\obj\**" />
    <Content Include="ttd-reqnroll-xunit3\**\*" Exclude="ttd-reqnroll-xunit3\**\bin\**;ttd-reqnroll-xunit3\**\obj\**" />
    <Content Include="ttd-reqnroll-xunit2\**\*" Exclude="ttd-reqnroll-xunit2\**\bin\**;ttd-reqnroll-xunit2\**\obj\**" />
    <Content Include="ttd-reqnroll-tunit\**\*" Exclude="ttd-reqnroll-tunit\**\bin\**;ttd-reqnroll-tunit\**\obj\**" />
    <Compile Remove="**\*" />
  </ItemGroup>

  <ItemGroup>
    <None Include="..\LICENSE" Pack="true" PackagePath="\" Link="LICENSE" />
    <None Include="README.md" Pack="true" PackagePath="\" />
  </ItemGroup>

</Project>
