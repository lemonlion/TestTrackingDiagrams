{
  "$schema": "http://json.schemastore.org/template",
  "author": "Aryeh Citron",
  "classifications": ["Test", "NUnit", "TestTrackingDiagrams", "Component Test"],
  "identity": "TestTrackingDiagrams.NUnit4.CSharp",
  "groupIdentity": "TestTrackingDiagrams.Test",
  "name": "TTD Component Tests (NUnit 4)",
  "shortName": "ttd-nunit4",
  "description": "A component test project using NUnit 4 with TestTrackingDiagrams for automatic sequence diagram and report generation.",
  "tags": { "language": "C#", "type": "project" },
  "sourceName": "TTD.NUnit4",
  "preferNameDirectory": true,
  "symbols": {
    "serviceName": { "type": "parameter", "datatype": "string", "defaultValue": "MyApi", "replaces": "SERVICE_NAME", "description": "Name of the service under test" },
    "downstreamService": { "type": "parameter", "datatype": "string", "defaultValue": "DownstreamService", "replaces": "DOWNSTREAM_SERVICE", "description": "Name of a downstream dependency service" },
    "downstreamPort": { "type": "parameter", "datatype": "int", "defaultValue": "15050", "replaces": "15050", "description": "Port number for the downstream service HTTP fake" },
    "Framework": { "type": "parameter", "datatype": "choice", "choices": [{ "choice": "net8.0" }, { "choice": "net9.0" }, { "choice": "net10.0" }], "defaultValue": "net10.0", "replaces": "net10.0" }
  },
  "sources": [{ "modifiers": [{ "exclude": ["**/bin/**", "**/obj/**"] }] }]
}
