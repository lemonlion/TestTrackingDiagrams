<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework />
    <TargetFrameworks>$(MultiTargetFrameworks)</TargetFrameworks>
    <Title>Test Tracking Diagrams MassTransit Extension</Title>
    <Description>MassTransit message tracking for test diagrams. Intercepts and classifies Send, Publish, and Consume operations across RabbitMQ, Azure Service Bus, Amazon SQS, and other transports with configurable verbosity.</Description>
    <GeneratePackageOnBuild>True</GeneratePackageOnBuild>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="MassTransit" Version="8.*" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\TestTrackingDiagrams\TestTrackingDiagrams.csproj" />
  </ItemGroup>
</Project>
