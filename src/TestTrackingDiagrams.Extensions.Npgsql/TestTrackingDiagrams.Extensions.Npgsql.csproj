<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework />
    <TargetFrameworks>$(MultiTargetFrameworks)</TargetFrameworks>
    <Title>Test Tracking Diagrams PostgreSQL (Npgsql) Extension</Title>
    <Description>PostgreSQL tracking for test diagrams via DiagnosticSource. Automatically intercepts all Npgsql SQL operations with zero production code changes. Classifies queries (Select, Insert, Update, Delete, Upsert, Merge, StoredProcedure, DDL) with configurable verbosity.</Description>
    <GeneratePackageOnBuild>True</GeneratePackageOnBuild>
  </PropertyGroup>
  <ItemGroup>
    <InternalsVisibleTo Include="TestTrackingDiagrams.Tests.Npgsql" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="Npgsql" Version="6.*" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\TestTrackingDiagrams\TestTrackingDiagrams.csproj" />
  </ItemGroup>
</Project>
