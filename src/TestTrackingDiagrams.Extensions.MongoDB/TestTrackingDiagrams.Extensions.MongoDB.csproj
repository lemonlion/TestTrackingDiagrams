<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework />
    <TargetFrameworks>$(MultiTargetFrameworks)</TargetFrameworks>
    <Title>Test Tracking Diagrams MongoDB Extension</Title>
    <Description>MongoDB tracking for test diagrams. Intercepts and classifies MongoDB operations (Find, Insert, Update, Delete, Aggregate, BulkWrite, and more) with configurable verbosity using the MongoDB driver's command event system.</Description>
    <GeneratePackageOnBuild>True</GeneratePackageOnBuild>
    <InternalsVisibleTo>TestTrackingDiagrams.Tests.MongoDB</InternalsVisibleTo>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="MongoDB.Driver" Version="3.*" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\TestTrackingDiagrams\TestTrackingDiagrams.csproj" />
  </ItemGroup>
</Project>
