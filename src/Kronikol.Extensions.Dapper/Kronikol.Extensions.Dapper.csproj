<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework />
    <TargetFrameworks>$(MultiTargetFrameworks)</TargetFrameworks>
    <Title>Test Tracking Diagrams Dapper Extension</Title>
    <Description>Dapper/ADO.NET tracking for test diagrams. Wraps DbConnection to intercept and classify SQL queries (Select, Insert, Update, Delete, StoredProcedure) with configurable verbosity. Works with any ADO.NET provider.</Description>
    <GeneratePackageOnBuild>True</GeneratePackageOnBuild>
  </PropertyGroup>
  <ItemGroup>
    <InternalsVisibleTo Include="Kronikol.Tests.Dapper" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\Kronikol\Kronikol.csproj" />
  </ItemGroup>
</Project>
