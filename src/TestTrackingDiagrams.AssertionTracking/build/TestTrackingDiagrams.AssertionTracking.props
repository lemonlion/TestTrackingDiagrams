<Project>

  <PropertyGroup>
    <!-- Support old property name for backward compatibility -->
    <TrackAssertionsEnabled Condition="'$(TrackAssertionsEnabled)' == '' AND '$(TrackAssertionsBetaEnabled)' != ''">$(TrackAssertionsBetaEnabled)</TrackAssertionsEnabled>
    <TrackAssertionsEnabled Condition="'$(TrackAssertionsEnabled)' == ''">true</TrackAssertionsEnabled>
    <_AssertionTrackingTaskDir>$(MSBuildThisFileDirectory)..\tasks\netstandard2.0\</_AssertionTrackingTaskDir>
  </PropertyGroup>

  <UsingTask TaskName="TestTrackingDiagrams.AssertionTracking.WeaveAssertionsTask"
             AssemblyFile="$(_AssertionTrackingTaskDir)TestTrackingDiagrams.AssertionTracking.dll" />

</Project>
