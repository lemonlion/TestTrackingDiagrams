<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework />
    <TargetFrameworks>$(MultiTargetFrameworks)</TargetFrameworks>
    <Title>Test Tracking Diagrams Google Cloud Spanner Extension</Title>
    <Description>Google Cloud Spanner tracking for test diagrams. Supports both ADO.NET (SpannerConnection) and low-level gRPC (SpannerClient) interception with configurable verbosity.</Description>
    <GeneratePackageOnBuild>True</GeneratePackageOnBuild>
    <InternalsVisibleTo>TestTrackingDiagrams.Tests.Spanner</InternalsVisibleTo>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Google.Cloud.Spanner.Data" Version="5.*" />
    <PackageReference Include="Google.Cloud.Spanner.V1" Version="5.*" />
    <PackageReference Include="Grpc.Core.Api" Version="2.*" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\TestTrackingDiagrams\TestTrackingDiagrams.csproj" />
  </ItemGroup>

</Project>
